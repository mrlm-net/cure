# Kubernetes Job: {{ .JobName }}
#
# Apply with:
#   kubectl apply -f k8s-job.yaml
#
# Watch logs with:
#   kubectl logs -l job-name={{ .JobName }} -n {{ .Namespace }} --follow
#
# Clean up manually (or wait for ttlSecondsAfterFinished=600):
#   kubectl delete job {{ .JobName }} -n {{ .Namespace }}
apiVersion: batch/v1
kind: Job
metadata:
  name: {{ .JobName }}
  namespace: {{ .Namespace }}
  labels:
    app.kubernetes.io/name: cure
    app.kubernetes.io/component: job-runner
spec:
  backoffLimit: 0
  ttlSecondsAfterFinished: 600
  template:
    metadata:
      labels:
        app.kubernetes.io/name: cure
        app.kubernetes.io/component: job-runner
        job-name: {{ .JobName }}
    spec:
      restartPolicy: Never
{{- if .NodeSelector}}
      nodeSelector:
{{- range $k, $v := .NodeSelector}}
        {{ $k }}: {{ $v }}
{{- end}}
{{- end}}
{{- if .Tolerations}}
      tolerations:
{{- range .Tolerations}}
        - key: "{{ .Key }}"
          operator: {{ .Operator }}
{{- if .Value}}
          value: "{{ .Value }}"
{{- end}}
          effect: {{ .Effect }}
{{- end}}
{{- end}}
      containers:
        - name: cure-runner
          image: {{ .Image }}
          resources:
            requests:
              cpu: 50m
              memory: 64Mi
            limits:
              cpu: 100m
              memory: 128Mi
          command:
            - cure
          args:
{{- range .CureArgs}}
            - "{{ . }}"
{{- end}}
